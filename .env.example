# Clé API Google Gemini (obligatoire pour l'assistant IA)
# Obtenez votre clé sur https://aistudio.google.com/app/apikey
VITE_API_KEY=your_gemini_api_key_here
# Compatibilité avec l'ancienne configuration :
# API_KEY=your_gemini_api_key_here

# Configuration Firebase (optionnelle - l'app fonctionne en mode démo sans Firebase)
# Créez votre projet sur https://console.firebase.google.com
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
