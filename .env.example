# Clé API Google Gemini (obligatoire pour l'assistant IA)
# Obtenez votre clé sur https://aistudio.google.com/app/apikey
VITE_API_KEY=your_gemini_api_key_here
# Compatibilité avec l'ancienne configuration :
# API_KEY=your_gemini_api_key_here

# Configuration Supabase (optionnelle - l'app fonctionne en mode démo sans Supabase)
# Créez votre projet sur https://supabase.com
# Récupérez l'URL et la clé anon dans : Paramètres du projet > API
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
